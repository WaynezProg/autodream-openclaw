{
  "id": "autodream",
  "name": "autoDream — Memory Consolidation",
  "description": "自動整理記憶：偵測重複、矛盾、過時條目，轉換相對時間",
  "version": "0.1.0",
  "main": "dist/index.js",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "intervalHours": { "type": "number", "default": 24 },
      "scheduleHour": { "type": "number", "default": 3 },
      "maxChangesPerRun": { "type": "number", "default": 20 },
      "dedupThreshold": { "type": "number", "default": 0.90 },
      "staleAgeDays": { "type": "number", "default": 60 },
      "scanLimit": { "type": "number", "default": 5000, "description": "Max memories to scan per run" },
      "allowedScopes": { "type": "array", "items": { "type": "string" }, "default": ["global"], "description": "Scopes allowed for background runs (default: global only)" },
      "autoMergeDuplicates": { "type": "boolean", "default": false },
      "autoFixTime": { "type": "boolean", "default": false },
      "autoDeleteStale": { "type": "boolean", "default": false },
      "minSessionsSinceLastRun": { "type": "number", "default": 3 },
      "notifyTarget": { "type": "string" },
      "llmEnabled": { "type": "boolean", "default": true, "description": "啟用 LLM 輔助分析" },
      "llmProvider": { "type": "string", "enum": ["openai", "anthropic"], "default": "openai", "description": "LLM provider" },
      "llmModel": { "type": "string", "default": "gpt-4o", "description": "LLM model identifier" },
      "llmBaseUrl": { "type": "string", "description": "Custom API base URL (e.g. Ollama)" },
      "llmApiKey": { "type": "string", "description": "API key (falls back to OPENAI_API_KEY / ANTHROPIC_API_KEY env var)" },
      "llmMaxCalls": { "type": "number", "default": 10, "description": "Max LLM calls per dream run" }
    }
  }
}
